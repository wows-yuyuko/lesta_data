<?xml version="1.0" encoding="UTF-8" standalone="no"?>

<root>
    <Implements>
        <Interface>VisionOwner</Interface>
        <Interface>AtbaOwner</Interface>
        <Interface>AirDefenceOwner</Interface>
        <Interface>BattleLogicEntityOwner</Interface>
        <Interface>DamageDealerOwner</Interface>
        <Interface>DebugDrawEntity</Interface>
        <Interface>HitLocationManagerOwner</Interface>
        <Interface>AviationOwner</Interface>
        <Interface>BuoyancyOwner</Interface>
        <Interface>WeatherOwner</Interface>
        <Interface>ModelOwner</Interface>
        <Interface>StatsOwner</Interface>
    </Implements>
    <LoDLevels>
        <level>0.1
            <label>ONLYOWNER</label>
        </level>
    </LoDLevels>
    <Volatile>
        <position></position>
        <yaw></yaw>
        <pitch></pitch>
        <roll></roll>
    </Volatile>
    <IsManualAoI>true</IsManualAoI>
    <Properties>
        <isOnForsage>
            <Type>BOOL</Type>
            <Flags>ALL_CLIENTS</Flags>
            <Default>0</Default>
        </isOnForsage>
        <regenCrewHpLimit>
            <Type>FLOAT32</Type>
            <Flags>ALL_CLIENTS</Flags>
            <Default>0.0</Default>
        </regenCrewHpLimit>
        <buoyancy>
            <Type>FLOAT32</Type>
            <Flags>ALL_CLIENTS</Flags>
        </buoyancy>
        <visibilityFlags>
            <Type>VISIBILITY_FLAG</Type>
            <Flags>ALL_CLIENTS</Flags>
        </visibilityFlags>
        <targetLocalPos>
            <Type>UINT16</Type>
            <Flags>ALL_CLIENTS</Flags>
        </targetLocalPos>
        <torpedoLocalPos>
            <Type>UINT16</Type>
            <Flags>ALL_CLIENTS</Flags>
        </torpedoLocalPos>
        <laserTargetLocalPos>
            <Type>UINT16</Type>
            <Flags>ALL_CLIENTS</Flags>
        </laserTargetLocalPos>
        <waveLocalPos>
            <Type>UINT16</Type>
            <Flags>ALL_CLIENTS</Flags>
        </waveLocalPos>
        <weaponLockFlags>
            <Type>UINT16</Type>
            <Flags>ALL_CLIENTS</Flags>
            <Default>0</Default>
        </weaponLockFlags>
        <owner>
            <Type>ENTITY_ID</Type>
            <Flags>ALL_CLIENTS</Flags>
        </owner>
        <shipConfig>
            <Type>SHIP_CONFIG</Type>
            <Flags>ALL_CLIENTS</Flags>
        </shipConfig>
        <crewModifiersCompactParams>
            <Type>CREW_MODIFIERS_COMPACT_PARAMS</Type>
            <Flags>ALL_CLIENTS</Flags>
        </crewModifiersCompactParams>
        <teamId>
            <Type>TEAM_ID</Type>
            <Flags>ALL_CLIENTS</Flags>
        </teamId>
        <isAlive>
            <Type>BOOL</Type>
            <Flags>ALL_CLIENTS</Flags>
            <Default>True</Default>
        </isAlive>
        <selectedWeapon>
            <Type>UINT32</Type>
            <Flags>ALL_CLIENTS</Flags>
            <Default>0</Default>
        </selectedWeapon>
        <serverSpeedRaw>
            <Type>UINT16</Type>
            <Flags>ALL_CLIENTS</Flags>
        </serverSpeedRaw>
        <maxServerSpeedRaw>
            <Type>UINT32</Type>
            <Flags>ALL_CLIENTS</Flags>
            <Default>0</Default>
            <SendLatestOnly>true</SendLatestOnly>
        </maxServerSpeedRaw>
        <speedSignDir>
            <Type>INT8</Type>
            <Flags>ALL_CLIENTS</Flags>
        </speedSignDir>
        <enginePower>
            <Type>UINT8</Type>
            <Flags>ALL_CLIENTS</Flags>
        </enginePower>
        <engineDir>
            <Type>INT8</Type>
            <Flags>ALL_CLIENTS</Flags>
        </engineDir>
        <ignoreMapBorders>
            <Type>BOOL</Type>
            <Flags>ALL_CLIENTS</Flags>
        </ignoreMapBorders>
        <debugText>
            <Type>ARRAY
                <of>ENTITY_DEBUG_TEXT</of>
            </Type>
            <Flags>ALL_CLIENTS</Flags>
        </debugText>
        <isBot>
            <Type>BOOL</Type>
            <Flags>ALL_CLIENTS</Flags>
            <Default>False</Default>
        </isBot>
        <miscsPresetsStatus>
            <Type>ARRAY
                <of>STRING</of>
            </Type>
            <Flags>ALL_CLIENTS</Flags>
        </miscsPresetsStatus>
        <draught>
            <Type>FLOAT32</Type>
            <Flags>ALL_CLIENTS</Flags>
        </draught>
        <blockedControls>
            <Type>BOOL</Type>
            <Flags>ALL_CLIENTS</Flags>
        </blockedControls>
        <isInvisible>
            <Type>BOOL</Type>
            <Flags>ALL_CLIENTS</Flags>
        </isInvisible>
        <ruddersAngle>
            <Type>FLOAT32</Type>
            <Flags>ALL_CLIENTS</Flags>
            <Default>0.0</Default>
        </ruddersAngle>
        <deepRuddersAngle>
            <Type>FLOAT32</Type>
            <Flags>ALL_CLIENTS</Flags>
            <Default>0.0</Default>
        </deepRuddersAngle>
        <triggeredSkillsData>
            <Type>BLOB</Type>
            <Flags>ALL_CLIENTS</Flags>
        </triggeredSkillsData>
        <hasActiveMainSquadron>
            <Type>BOOL</Type>
            <Flags>ALL_CLIENTS</Flags>
        </hasActiveMainSquadron>
        <isInRageMode>
            <Type>BOOL</Type>
            <Flags>ALL_CLIENTS</Flags>
            <Default>False</Default>
        </isInRageMode>
        <respawnTime>
            <Type>UINT16</Type>
            <Flags>ALL_CLIENTS</Flags>
        </respawnTime>
        <deathSettings>
            <Type>GAMEPARAMS</Type>
            <Flags>ALL_CLIENTS</Flags>
        </deathSettings>
        <state>
            <Type>VEHICLE_STATE</Type>
            <Flags>ALL_CLIENTS</Flags>
        </state>
        <oilLeakState>
            <Type>UINT8</Type>
            <Flags>ALL_CLIENTS</Flags>
        </oilLeakState>
        <movementControlBlockType>
            <Type>UINT8</Type>
            <Flags>ALL_CLIENTS</Flags>
            <Default>0</Default>
        </movementControlBlockType>
        <isLockedForAirSupportBuff>
            <Type>BOOL</Type>
            <Flags>ALL_CLIENTS</Flags>
            <Default>False</Default>
        </isLockedForAirSupportBuff>
        <teamBuildType>
            <Type>TEAM_BUILD_TYPE</Type>
            <Flags>ALL_CLIENTS</Flags>
        </teamBuildType>
        <isResurrecting>
            <Type>BOOL</Type>
            <Flags>ALL_CLIENTS</Flags>
            <Default>0</Default>
        </isResurrecting>
        <underMissileThreat>
            <Type>UINT8</Type>
            <Flags>ALL_CLIENTS</Flags>
            <Default>0</Default>
        </underMissileThreat>
    </Properties>
    <ClientMethods>
        <onAvatarReady></onAvatarReady>
        <onConsumableInterrupted>
            <Arg>UINT8</Arg>
        </onConsumableInterrupted>
        <setAmmoForWeapon>
            <Arg>WEAPON_TYPE</Arg>
            <Arg>GAMEPARAMS_ID</Arg>
            <Arg>BOOL</Arg>
        </setAmmoForWeapon>
        <onWeaponStateSwitched>
            <Arg>WEAPON_TYPE</Arg>
            <Arg>UINT8</Arg>
        </onWeaponStateSwitched>
        <setShotDecals>
            <Arg>ARRAY
                <of>UINT64</of>
            </Arg>
        </setShotDecals>
        <receiveDamagesOnShip>
            <Arg>ARRAY
                <of>DAMAGES</of>
            </Arg>
            <VariableLengthHeaderSize>2</VariableLengthHeaderSize>
        </receiveDamagesOnShip>
        <consumableUsed>
            <Arg>INT8</Arg>
            <Arg>FLOAT32</Arg>
        </consumableUsed>
        <syncGun>
            <Arg>UINT8</Arg>
            <Arg>INT32</Arg>
            <Arg>FLOAT32</Arg>
            <Arg>FLOAT32</Arg>
            <Arg>BOOL</Arg>
            <Arg>FLOAT32</Arg>
            <Arg>ARRAY
                <of>STRING</of>
            </Arg>
        </syncGun>
        <syncWaveGun>
            <Arg>INT32</Arg>
            <Arg>FLOAT32</Arg>
            <Arg>FLOAT32</Arg>
            <Arg>FLOAT32</Arg>
            <Arg>BOOL</Arg>
            <Arg>FLOAT32</Arg>
        </syncWaveGun>
        <syncTorpedoTube>
            <Arg>INT32</Arg>
            <Arg>FLOAT32</Arg>
            <Arg>FLOAT32</Arg>
            <Arg>FLOAT32</Arg>
            <Arg>BOOL</Arg>
            <Arg>FLOAT32</Arg>
            <Arg>INT32</Arg>
        </syncTorpedoTube>
        <syncTorpedoState>
            <Arg>UINT8</Arg>
        </syncTorpedoState>
        <syncMissileLauncherGroups>
            <Args>
                <dump>ARRAY
                    <of>MISSILE_RELOADER</of>
                </dump>
            </Args>
        </syncMissileLauncherGroups>
        <syncArmorSegment>
            <Args>
                <index>UINT8</index>
                <thickness>FLOAT</thickness>
            </Args>
        </syncArmorSegment>
        <syncArmorSegments>
            <Args>
                <segments>ARRAY
                    <of>FLOAT</of>
                </segments>
            </Args>
        </syncArmorSegments>
        <kill>
            <Args>
                <crackNum>INT8</crackNum>
                <deathReasonId>DEATH_REASON_ID</deathReasonId>
                <deathSubtype>UINT8</deathSubtype>
                <deathReasonAmmoId>GAMEPARAMS_ID</deathReasonAmmoId>
                <sinkTime>FLOAT</sinkTime>
                <sinkType>UINT8</sinkType>
                <trimBank>VECTOR2</trimBank>
                <collisionPos>VECTOR3</collisionPos>
                <linearVelocity>VECTOR3</linearVelocity>
                <trimCoeff>FLOAT</trimCoeff>
            </Args>
        </kill>
        <forceSink>
            <Arg>FLOAT</Arg>
        </forceSink>
        <bodySinkPartLurched>
            <Arg>FLOAT</Arg>
        </bodySinkPartLurched>
        <shootTorpedo>
            <Args>
                <gunID>INT32</gunID>
                <direction>VECTOR3</direction>
                <salvoID>INT32</salvoID>
                <numShotsBefore>INT32</numShotsBefore>
            </Args>
        </shootTorpedo>
        <shootDepthCharge>
            <Args>
                <gunID>INT32</gunID>
                <bombIdx>UINT16</bombIdx>
                <tickOffset>FLOAT</tickOffset>
            </Args>
        </shootDepthCharge>
        <syncSurfacingTime>
            <Arg>INT32</Arg>
        </syncSurfacingTime>
        <receivePingerShot>
            <Arg>INT32</Arg>
            <Arg>FLOAT</Arg>
        </receivePingerShot>
        <shootOnClient>
            <Arg>WEAPON_TYPE</Arg>
            <Arg>GUN_BITS</Arg>
        </shootOnClient>
        <shootChargeableDrumOnClient>
            <Arg>WEAPON_TYPE</Arg>
            <Arg>CHARGEABLE_DRUM_GUN_BITS</Arg>
        </shootChargeableDrumOnClient>
        <chargeGuns>
            <Arg>WEAPON_TYPE</Arg>
            <Arg>GUN_BITS</Arg>
        </chargeGuns>
        <prepareChargeLaser>
            <Arg>UINT8</Arg>
            <Arg>VECTOR3</Arg>
        </prepareChargeLaser>
        <stopShootingGuns>
            <Arg>WEAPON_TYPE</Arg>
            <Arg>GUN_BITS</Arg>
        </stopShootingGuns>
        <syncShipCracks>
            <Arg>BLOB</Arg>
            <Arg>BLOB</Arg>
        </syncShipCracks>
        <makeShipCracksActive></makeShipCracksActive>
        <interrupt></interrupt>
        <syncShipPhysics>
            <Arg>INT8</Arg>
            <Arg>BLOB</Arg>
            <VariableLengthHeaderSize>2</VariableLengthHeaderSize>
        </syncShipPhysics>
        <setStateForWeapon>
            <Arg>WEAPON_TYPE</Arg>
            <Arg>BOOL</Arg>
            <Arg>BLOB</Arg>
            <VariableLengthHeaderSize>2</VariableLengthHeaderSize>
        </setStateForWeapon>
        <setUniqueSkills>
            <Arg>BLOB</Arg>
        </setUniqueSkills>
        <setConsumables>
            <Arg>BLOB</Arg>
        </setConsumables>
        <setSqsConsumables>
            <Arg>PLANE_ID</Arg>
            <Arg>BLOB</Arg>
        </setSqsConsumables>
        <stopVarys></stopVarys>
        <onShotDecal>
            <Arg>UINT64</Arg>
        </onShotDecal>
        <receiveMirrorDamage>
            <Arg>FLOAT</Arg>
        </receiveMirrorDamage>
        <forceReloadWeapon>
            <Args>
                <weaponType>WEAPON_TYPE</weaponType>
            </Args>
        </forceReloadWeapon>
        <uniqueTriggerActivated></uniqueTriggerActivated>
        <onConsumableEnabled>
            <Args>
                <battleEvent>BATTLE_EVENT</battleEvent>
                <reason>REASON_ID</reason>
            </Args>
        </onConsumableEnabled>
        <onReseted>
            <Args>
                <yaw>FLOAT</yaw>
                <resetConsumablesState>BOOL</resetConsumablesState>
                <resetConsumablesCount>BOOL</resetConsumablesCount>
                <initialSpeed>FLOAT</initialSpeed>
            </Args>
        </onReseted>
        <setAirDefenseState>
            <Arg>BLOB</Arg>
        </setAirDefenseState>
        <onPrioritySectorSet>
            <Arg>INT8</Arg>
            <Arg>FLOAT</Arg>
        </onPrioritySectorSet>
        <onNextPrioritySectorSet>
            <Arg>INT8</Arg>
        </onNextPrioritySectorSet>
        <teleport>
            <Arg>VECTOR3</Arg>
            <Arg>FLOAT</Arg>
            <Arg>BOOL</Arg>
        </teleport>
        <setNewSpeed>
            <Arg>FLOAT</Arg>
        </setNewSpeed>
        <shootWaveGun>
            <Arg>GUN_ID</Arg>
            <Arg>FLOAT</Arg>
        </shootWaveGun>
        <receiveGunSyncRotations>
            <Arg>WEAPON_TYPE</Arg>
            <Arg>GUN_DIRECTIONS</Arg>
        </receiveGunSyncRotations>
        <receiveOutgoingWaveAssignedTorpedo>
            <Args>
                <waveID>OUTGOING_WAVE_ID</waveID>
            </Args>
        </receiveOutgoingWaveAssignedTorpedo>
        <receiveAllTargetOutgoingWavesRemoval>
            <Args>
                <targetID>ENTITY_ID</targetID>
            </Args>
        </receiveAllTargetOutgoingWavesRemoval>
        <receiveSingleOutgoingWaveRemoval>
            <Args>
                <waveID>OUTGOING_WAVE_ID</waveID>
            </Args>
        </receiveSingleOutgoingWaveRemoval>
        <receiveAllOutgoingWavesRemoval></receiveAllOutgoingWavesRemoval>
        <receiveSingleIncomingWaveRemoval>
            <Args>
                <shooterID>ENTITY_ID</shooterID>
                <waveID>OUTGOING_WAVE_ID</waveID>
            </Args>
        </receiveSingleIncomingWaveRemoval>
        <receiveNewOutgoingWave>
            <Args>
                <waveID>OUTGOING_WAVE_ID</waveID>
                <targetID>ENTITY_ID</targetID>
                <lifeTime>FLOAT</lifeTime>
                <localPosition>VECTOR3</localPosition>
            </Args>
        </receiveNewOutgoingWave>
        <receiveOutgoingWaveInvisiblePointUpdate>
            <Args>
                <waveID>OUTGOING_WAVE_ID</waveID>
                <position>NULLABLE_VECTOR3</position>
            </Args>
        </receiveOutgoingWaveInvisiblePointUpdate>
        <receiveOutgoingWavesDump>
            <Arg>ARRAY
                <of>ATTACHED_PINGER_WAVE</of>
            </Arg>
        </receiveOutgoingWavesDump>
        <receiveNewIncomingWave>
            <Args>
                <shooterID>ENTITY_ID</shooterID>
                <waveID>OUTGOING_WAVE_ID</waveID>
                <localPosition>VECTOR3</localPosition>
                <lifetime>FLOAT</lifetime>
                <waveYaw>FLOAT</waveYaw>
            </Args>
        </receiveNewIncomingWave>
        <receiveIncomingWaveUpdate>
            <Args>
                <shooterID>ENTITY_ID</shooterID>
                <waveID>OUTGOING_WAVE_ID</waveID>
                <lifetime>FLOAT</lifetime>
                <waveYaw>FLOAT</waveYaw>
            </Args>
        </receiveIncomingWaveUpdate>
        <receiveTorpedoAcousticShooterModeChange>
            <Args>
                <acousticShooterMode>SUBMARINE_ACOUSTIC_SHOOTER_MODE</acousticShooterMode>
            </Args>
        </receiveTorpedoAcousticShooterModeChange>
        <syncRageMode>
            <Args>
                <hitCounter>INT8</hitCounter>
                <state>INT8</state>
                <stateTimePassed>FLOAT</stateTimePassed>
                <currentActivationCount>INT8</currentActivationCount>
            </Args>
        </syncRageMode>
        <setWildFireState>
            <Args>
                <wildFireState>WILD_FIRE_STATE</wildFireState>
            </Args>
        </setWildFireState>
        <reloadVehicle></reloadVehicle>
        <setUIEnabled>
            <Args>
                <uiEnabled>BOOL</uiEnabled>
            </Args>
        </setUIEnabled>
        <setWeaponAvailable>
            <Args>
                <weaponTypes>ARRAY
                    <of>UINT8</of>
                </weaponTypes>
                <isAvailable>BOOL</isAvailable>
            </Args>
        </setWeaponAvailable>
        <startFoghorn></startFoghorn>
        <stopFoghorn></stopFoghorn>
        <syncFoghorn>
            <Args>
                <state>UINT8</state>
                <duration>FLOAT</duration>
                <delay>FLOAT</delay>
            </Args>
        </syncFoghorn>
        <reduceWeaponReloadTime>
            <Args>
                <weaponType>WEAPON_TYPE</weaponType>
                <reduceTime>FLOAT</reduceTime>
            </Args>
        </reduceWeaponReloadTime>
        <onDamageAbsorbedByShield>
            <Args>
                <damagerId>ENTITY_ID</damagerId>
                <absorbedDamage>FLOAT</absorbedDamage>
                <position>VECTOR3</position>
            </Args>
        </onDamageAbsorbedByShield>
        <onResurrected>
            <Args>
                <shipConfig>SHIP_CONFIG</shipConfig>
                <yaw>FLOAT</yaw>
                <resetConsumablesState>BOOL</resetConsumablesState>
                <resetConsumablesCount>BOOL</resetConsumablesCount>
                <initialSpeed>FLOAT</initialSpeed>
                <wasAlive>BOOL</wasAlive>
            </Args>
        </onResurrected>
        <parryMissiles></parryMissiles>
        <launchMissile>
            <Args>
                <launcherGroupIndex>UINT8</launcherGroupIndex>
                <launcherIndex>UINT8</launcherIndex>
                <spawnPosition>VECTOR3</spawnPosition>
                <spawnYaw>FLOAT</spawnYaw>
            </Args>
        </launchMissile>
    </ClientMethods>
    <CellMethods>
        <onClientEnterWorld>
            <Exposed></Exposed>
        </onClientEnterWorld>
        <onClientLeaveWorld>
            <Exposed></Exposed>
        </onClientLeaveWorld>
        <onAvatarReady>
            <Exposed></Exposed>
        </onAvatarReady>
        <send_commonCMD>
            <Exposed>OWN_CLIENT</Exposed>
            <Args>
                <command>QUICK_COMMAND</command>
            </Args>
        </send_commonCMD>
        <startFoghorn>
            <Exposed></Exposed>
        </startFoghorn>
        <stopFoghorn>
            <Exposed></Exposed>
        </stopFoghorn>
    </CellMethods>
    <BaseMethods></BaseMethods>
    <shouldBackup>false</shouldBackup>
</root>

