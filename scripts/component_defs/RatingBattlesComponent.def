<root>
	<BaseMethods>
		<syncSeasonDossiersAndBestProgressInfo>
			<Exposed/>
			<Args>
				<seasonID> UINT16 </seasonID>
			</Args>
		</syncSeasonDossiersAndBestProgressInfo>
		<syncSeasonDossiersAndBestProgressInfoForVehicle>
			<Exposed/>
			<Args>
				<seasonID> UINT16 </seasonID>
				<vehicleID> GAMEPARAMS_ID </vehicleID>
			</Args>
		</syncSeasonDossiersAndBestProgressInfoForVehicle>
	</BaseMethods>

	<ClientMethods>
		<receiveSeasonProgress>
			<Args>
				<seasonProgress> PYTHON </seasonProgress>
			</Args>
		</receiveSeasonProgress>
		<receiveSeasonStats>
			<Args>
				<seasonStats> PYTHON </seasonStats>
			</Args>
		</receiveSeasonStats>
		<receiveSeasonIDs>
			<Args>
				<seasonIDs>ARRAY<of>UINT32</of></seasonIDs>
			</Args>
		</receiveSeasonIDs>
		<receiveBestProgressInfo>
			<Args>
				<bestLeague>UINT32</bestLeague>
				<bestLeagueProgress>UINT32</bestLeagueProgress>
			</Args>
		</receiveBestProgressInfo>
	</ClientMethods>
	
	<ofEntity>
		<Account/>
	</ofEntity>
	
	<ofBWComponent>
		<base/>
		<bot/>
		<client/>
	</ofBWComponent>
</root>
