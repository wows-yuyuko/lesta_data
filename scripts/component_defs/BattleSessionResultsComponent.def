<root>
	<BaseMethods>
		<onNewBuildingSpawned>
			<Args>
				<buildingData> ZIPPED_PYTHON </buildingData>
			</Args>
		</onNewBuildingSpawned>

		<onNewBotSpawned>
			<Args>
				<botData> ZIPPED_PYTHON </botData>
			</Args>
		</onNewBotSpawned>

		<onPlayerBanned>
			<Args>
				<playerSPAID> DB_ID </playerSPAID>
			</Args>
		</onPlayerBanned>

		<onPlayerResurrected>
			<Args>
				<playerDBID> DB_ID </playerDBID>
				<shipConfig> SHIP_CONFIG </shipConfig>
			</Args>
		</onPlayerResurrected>
	</BaseMethods>

	<ofEntity>
		<BattleSession/>
	</ofEntity>

	<ofBWComponent>
		<base/>
	</ofBWComponent>
</root>
